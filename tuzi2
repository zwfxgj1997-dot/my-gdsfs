rules:
  # 强制 Google Play 相关域名走 Googleplay 代理组
  - DOMAIN-SUFFIX,play.google.com,Googleplay
  - DOMAIN,play-fe.googleapis.com,Googleplay
  - DOMAIN-SUFFIX,googleapis.com,Googleplay
  - DOMAIN-SUFFIX,googleusercontent.com,Googleplay
  - DOMAIN-SUFFIX,gstatic.com,Googleplay
  
  # IP 检测工具，方便确认当前 IP 归属地
  - DOMAIN-SUFFIX,ipapi.co,Googleplay
  - DOMAIN-SUFFIX,ip-api.com,Googleplay
  - DOMAIN-SUFFIX,api.ip.sb,Googleplay
  - DOMAIN-SUFFIX,ipinfo.io,Googleplay

  # 普通代理分流
  - DOMAIN-KEYWORD,game,Proxies
  - DOMAIN-KEYWORD,googlevideo,Proxies
  - DOMAIN-KEYWORD,github,Proxies
  - DOMAIN-SUFFIX,github.com,Proxies
  
  # 直连规则
  - DOMAIN-KEYWORD,cn,DIRECT
  - DOMAIN-SUFFIX,baidu.com,DIRECT
  - GEOIP,CN,DIRECT
  
  # 兜底规则
  - MATCH,Proxies
